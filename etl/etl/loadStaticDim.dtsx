    <DTS:Executable
      DTS:refId="Package\load dim time"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{EEB1BB6C-CF27-44B4-AEE9-8570373A79D4}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="load dim time"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{6D18D4B4-728C-4F01-9327-39E43595397E}"
          SQLTask:SqlStatementSource="DECLARE @TuNgay DATE = CONVERT(DATE, ?, 23);&#xA;DECLARE @DenNgay DATE = CONVERT(DATE, ?, 23);&#xA;&#xA;WITH RawDateCTE AS (&#xA;    SELECT @TuNgay AS Ngay&#xA;    UNION ALL&#xA;    SELECT DATEADD(DAY, 1, Ngay)&#xA;    FROM RawDateCTE&#xA;    WHERE Ngay &lt; @DenNgay&#xA;),&#xA;CalculatedDateCTE AS (&#xA;    SELECT &#xA;        CONVERT(INT, CONVERT(VARCHAR(8), Ngay, 112)) AS TimeKey, -- Tính sẵn TimeKey ở đây&#xA;        Ngay,&#xA;        DAY(Ngay) AS NgayTrongThang,&#xA;        MONTH(Ngay) AS Thang,&#xA;        DATEPART(QUARTER, Ngay) AS Quy,&#xA;        YEAR(Ngay) AS Nam,&#xA;        DATEPART(WEEK, Ngay) AS Tuan,&#xA;        DATEPART(WEEKDAY, Ngay) AS ThuTrongTuan,&#xA;        CASE DATEPART(WEEKDAY, Ngay)&#xA;            WHEN 1 THEN N'Chủ Nhật'&#xA;            WHEN 2 THEN N'Thứ Hai'&#xA;            WHEN 3 THEN N'Thứ Ba'&#xA;            WHEN 4 THEN N'Thứ Tư'&#xA;            WHEN 5 THEN N'Thứ Năm'&#xA;            WHEN 6 THEN N'Thứ Sáu'&#xA;            WHEN 7 THEN N'Thứ Bảy'&#xA;        END AS TenThu&#xA;    FROM RawDateCTE&#xA;)&#xA;INSERT INTO DIM_THOI_GIAN (TimeKey, Ngay, NgayTrongThang, Thang, Quy, Nam, Tuan, ThuTrongTuan, TenThu)&#xA;SELECT TimeKey, Ngay, NgayTrongThang, Thang, Quy, Nam, Tuan, ThuTrongTuan, TenThu&#xA;FROM CalculatedDateCTE cte&#xA;WHERE NOT EXISTS (&#xA;    SELECT 1 &#xA;    FROM DIM_THOI_GIAN dim &#xA;    WHERE dim.TimeKey = cte.TimeKey -- Đúng ý bạn: So sánh INT vs INT chuẩn tốc độ!&#xA;)&#xA;OPTION (MAXRECURSION 0);" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask">
          <SQLTask:ParameterBinding
            SQLTask:ParameterName="0"
            SQLTask:DtsVariableName="$Package::tuNgay"
            SQLTask:ParameterDirection="Input"
            SQLTask:DataType="7"
            SQLTask:ParameterSize="-1" />
          <SQLTask:ParameterBinding
            SQLTask:ParameterName="1"
            SQLTask:DtsVariableName="$Package::denNgay"
            SQLTask:ParameterDirection="Input"
            SQLTask:DataType="7"
            SQLTask:ParameterSize="-1" />
        </SQLTask:SqlTaskData>
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\load dim_status_order"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{41A9EF25-EA14-48B1-92C6-3504E7C66A3E}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="load dim_status_order"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{6D18D4B4-728C-4F01-9327-39E43595397E}"
          SQLTask:SqlStatementSource="&#xA;IF NOT EXISTS (SELECT 1 FROM DIM_STATUS_ORDER WHERE TrangThai = N'đang xử lý')&#xA;BEGIN&#xA;    INSERT INTO DIM_STATUS_ORDER (TrangThai) VALUES (N'đang xử lý');&#xA;END;&#xA;&#xA;IF NOT EXISTS (SELECT 1 FROM DIM_STATUS_ORDER WHERE TrangThai = N'đã giao')&#xA;BEGIN&#xA;    INSERT INTO DIM_STATUS_ORDER (TrangThai) VALUES (N'đã giao');&#xA;END;&#xA;&#xA;IF NOT EXISTS (SELECT 1 FROM DIM_STATUS_ORDER WHERE TrangThai = N'đã hủy')&#xA;BEGIN&#xA;    INSERT INTO DIM_STATUS_ORDER (TrangThai) VALUES (N'đã hủy');&#xA;END;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>
