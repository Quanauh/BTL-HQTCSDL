        <SQLTask:SqlTaskData
          SQLTask:Connection="{6D18D4B4-728C-4F01-9327-39E43595397E}"
          SQLTask:SqlStatementSource="&#xA;IF NOT EXISTS (SELECT 1 FROM DIM_STATUS_ORDER WHERE TrangThai = N'đang xử lý')&#xA;BEGIN&#xA;    INSERT INTO DIM_STATUS_ORDER (TrangThai) VALUES (N'đang xử lý');&#xA;END;&#xA;&#xA;IF NOT EXISTS (SELECT 1 FROM DIM_STATUS_ORDER WHERE TrangThai = N'đã giao')&#xA;BEGIN&#xA;    INSERT INTO DIM_STATUS_ORDER (TrangThai) VALUES (N'đã giao');&#xA;END;&#xA;&#xA;IF NOT EXISTS (SELECT 1 FROM DIM_STATUS_ORDER WHERE TrangThai = N'đã hủy')&#xA;BEGIN&#xA;    INSERT INTO DIM_STATUS_ORDER (TrangThai) VALUES (N'đã hủy');&#xA;END;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
